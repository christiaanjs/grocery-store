{
  "name": "grocery-store",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "migrate:local": "wrangler d1 migrations apply grocery-store-db --local",
    "migrate:prod": "wrangler d1 migrations apply grocery-store-db --remote",
    "migration:new": "wrangler d1 migrations create grocery-store-db",
    "logs": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.0.0"
  }
}
