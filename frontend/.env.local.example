# Copy to .env.development.local for local development

# The Worker's local dev URL (wrangler dev runs on port 8787 by default)
VITE_WORKER_URL=http://localhost:8787

# Set to match DEV_TOKEN in .dev.vars to skip the GitHub OAuth flow entirely.
# The browser will send X-Dev-Token on every MCP request instead of a JWT.
# Leave unset (or empty) to use the normal OAuth flow.
# VITE_DEV_TOKEN=your-dev-token
